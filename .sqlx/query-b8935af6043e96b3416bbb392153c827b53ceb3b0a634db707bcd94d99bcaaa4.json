  "query": "\n            SELECT id, series_id, user_id, tmdb_series_id, rating, liked, disliked, was_recommended as \"was_recommended!\", created_at\n            FROM reviews\n            WHERE user_id = $1 AND tmdb_series_id = $2\n            ORDER BY created_at DESC\n            LIMIT 1\n            ",
